import java.util.*;

public class Solution{

	public int maxSubArray(int[]nums){
		if(nums == null || nums.length == 0) return 0;
		if(nums.length == 1) return nums[0];
		int n = nums.length;

		int sum = 0;
		int maxSum = Integer.MIN_VALUE;
		int temp = 0;
		int start = 0;
		int end = 0;

		for(int i = 0 ; i < n; i++){
			sum += nums[i];

			if(sum > maxSum){
				maxSum = sum;
				start = temp;
				end = i;
			}
			if(sum < 0){
				sum = 0;
				temp = i + 1;
			}
		}
		return maxSum;
	}
}
